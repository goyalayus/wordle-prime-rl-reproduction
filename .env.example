# Hugging Face token (required for push_to_hub)
# Get from https://huggingface.co/settings/tokens
HF_TOKEN=your_token_here

# Target repo for adapter checkpoints (e.g. username/wordle-lora-qwen06b)
HF_REPO_ID=yourusername/wordle-lora-qwen06b

# Weights & Biases (optional, for --wandb train/eval loss logging)
# Get from https://wandb.ai/authorize
WANDB_API_KEY=your_key_here
